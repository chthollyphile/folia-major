{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "folia-major",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-04-02",
  "secrets": {
    "required": [
      "GEMINI_API_KEY",
      "OPENAI_API_KEY"
    ]
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  }
}
